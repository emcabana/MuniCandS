evlin=function(u,f){ff=c(0,sort(f),1)#
	sf=max(which(ff<=u))#
	if(sf==length(ff))return(1) else return(((u-ff[sf])*(sf)+(ff[sf+1]-u)*(sf-1))/((ff[sf+1]-ff[sf])*(length(f)+1)))#
 }#
# Código para la prueba HR, por no estar en spunif ni en otro paquete#
HR.test <- function(x, B = 500) {#
  # x: matriz n x p de vectores unitarios#
  n <- nrow(x)#
  p <- ncol(x)#
  # Estadística observada: suma de cosenos entre pares#
  theta <- acos(pmin(pmax(x %*% t(x), -1), 1))  # matriz de ángulos#
  stat_obs <- sum(cos(theta[lower.tri(theta)]))#
  # Bootstrap bajo H0: datos uniformes en la esfera#
  stat_boot <- numeric(B)#
  for (b in 1:B) {#
    u <- matrix(rnorm(n * p), n, p)#
    u <- u / sqrt(rowSums(u^2))#
    theta_b <- acos(pmin(pmax(u %*% t(u), -1), 1))#
    stat_boot[b] <- sum(cos(theta_b[lower.tri(theta_b)]))#
  }#
  pval <- mean(stat_boot >= stat_obs)#
  list(statistic = stat_obs, p.value = pval)#
}#
