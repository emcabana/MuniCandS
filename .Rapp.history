  # Initial processing of the data  #
 dataproc=function(Z,type){#
  X <- Z#
  # To test uniformity on S apply a map M:S->C that preserves uniformity (using C++)#
  if(type=='US'){#
  	X <- c()#
  	for(nn in 1:nrow(Z))X <- rbind(X,S2C(Z[nn,]))#
  	}#
  # To test isotropy write Z=rho times Z0, Z0 in S#
  # then apply M to Z0 and rank/(n+1) to diag(rho)#
  if(type=='I'){#
  	rho=sqrt(rowSums(Z^2))#
  	Z0=Z/rho#
	X=c()#
  	for(nn in 1:nrow(Z))X=rbind(X,S2C(Z0[nn,]))#
  	X=cbind(X,rank(rho)/(nrow(Z)+1))#
  	}#
  # To test normality, standardize the sample and apply Phi#
  if(type=='N'){#
  	ZC=Z-rep(1,nrow(Z))%*%t(colMeans(Z))#
  	variance=t(ZC)%*%ZC/nrow(Z)#
  	eig=eigen(variance)#
  	X=pnorm(ZC%*%eig$vectors%*%diag(eig$values^(-.5))%*%t(eig$vectors))#
  }	else variance<-NA#
return(list(X=X,variance=variance))#
}#
#
   # Generation of the subsets H of J={0,1,...,p}#
  genlist=function(hmin,hmax,p){#
  H_list <- list()#
  for (h in max(1,hmin):min(hmax, p)) {#
    H_list <- c(H_list, combn(p, h, simplify = FALSE))#
  }#
  return(H_list)#
}#
#
  #Computation of the statistics ||T_H||^2#
  calcest=function(X,H_list){#
	T_H2=c()#
	for(H in H_list)T_H2=c(T_H2,calc_est(X,as.integer(H)))#
	return(T_H2)#
	}#
  # Simulation of samples under the null hypothesis#
  simsamp=function(n,p,variance=NA,type=type){#
	if(type=='N'){X <- rmvnorm(n,rep(0,p),variance)#
		XC=X-rep(1,nrow(X))%*%t(colMeans(X))#
  	variance=t(XC)%*%XC/nrow(X)#
  	eig=eigen(variance)#
  	X=pnorm(XC%*%eig$vectors%*%diag(eig$values^(-.5))%*%t(eig$vectors))#
		}else X <- matrix(runif(n*p),n,p)#
	if(type=='I')X[,p] <- rank(X[,p])/(n+1)#
	return(X)#
}#
#
  # Estimation of the p-values by simulation#
  calcpvals=function(T_H2,n,p,repet,H_list,variance=diag(p),type){#
  	counter=rep(0,length(T_H2))#
  	for(rep in 1:repet){#
  		if(type=='N')samp=simsamp(n,p,variance=variance,type=type) else samp=simsamp(n,p,type=type)#
  		T2=calcest(samp,H_list)#
  		counter=counter+(sign(T2-T_H2)+1)/2#
  	}#
  	return(counter/repet)#
  }#
#
