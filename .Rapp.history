cppFunction('#
// [[Rcpp::depends(RcppArmadillo)]]#
#include <RcppArmadillo.h>#
using namespace Rcpp;#
#
// [[Rcpp::export]]#
double calc_est_arma(const arma::mat& X, const arma::uvec& H) {#
  int n = X.n_rows;#
  double T = 0.0;#
#
  for (int h = 0; h < n; ++h) {#
    for (int i = 0; i < n; ++i) {#
      double prod = 1.0;#
      for (size_t j = 0; j < H.n_elem; ++j) {#
        double val_h = X(h, H[j]);#
        double val_i = X(i, H[j]);#
        double term = (std::pow(val_h, 2.0) + std::pow(val_i, 2.0)) / 2.0 - std::max(val_h, val_i) + 1.0 / 3.0;#
        prod *= term;#
      }#
      T += prod;#
    }#
  }#
#
  return T / n;#
}#
')#
cppFunction('#
NumericVector S2Cpi(NumericVector x) {#
	int p = x.size() - 1;#
	NumericVector phi(p);#
	for (int j = 0; j < p; ++j) {#
    double denom = 1.0;#
    for (int k = 0; k < j; ++k) {#
      denom *= sin(phi[k]);#
    }#
    phi[j] = acos(x[j] / (denom == 0 ? 1.0 : denom));#
  }#
  if ( x[p] < 0 ) {#
        phi[p-1]=2*M_PI-phi[p-1];#
    } #
  return phi;#
}#
')
cppFunction('#
// [[Rcpp::depends(RcppArmadillo)]]#
#include <RcppArmadillo.h>#
using namespace Rcpp;#
#
// [[Rcpp::export]]#
double calc_est_arma(const arma::mat& X, const arma::uvec& H) {#
  int n = X.n_rows;#
  double T = 0.0;#
#
  for (int h = 0; h < n; ++h) {#
    for (int i = 0; i < n; ++i) {#
      double prod = 1.0;#
      for (size_t j = 0; j < H.n_elem; ++j) {#
        double val_h = X(h, H[j]);#
        double val_i = X(i, H[j]);#
        double term = (std::pow(val_h, 2.0) + std::pow(val_i, 2.0)) / 2.0 - std::max(val_h, val_i) + 1.0 / 3.0;#
        prod *= term;#
      }#
      T += prod;#
    }#
  }#
#
  return T / n;#
}#
')
