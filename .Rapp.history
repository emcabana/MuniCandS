S2C <- function(Z) {#
  if (is.matrix(Z)) {#
    n <- nrow(Z)#
    U <- matrix(NA, n, ncol(Z))#
    for (i in 1:n) U[i, ] <- Cpi2C(S2Cpi(Z[i, ]))#
  } else {#
    U <- Cpi2C(S2Cpi(Z))#
  }#
  U#
}#
