library(copula)#
muesnorm=function(n,p,rho){mues=c()#
	for(i in 1:n)mues=rbind(mues,C2S(rCopula(1,normalCopula(rho,p))))#
	return(mues)#
}#
muesclay=function(n,p,kk){#
	copula_clayton <- claytonCopula(param = kk, dim = p)#
	mues <- C2S(rCopula(n, copula_clayton))#
	return(mues)#
}#
#
muesgumbel=function(n,p,kk){#
	copula_gumbel <- gumbelCopula(param = kk, dim = p)#
	mues <- C2S(rCopula(n, copula_gumbel))#
	return(mues)#
}#
