if (!requireNamespace('Rcpp', quietly = TRUE))install.packages('Rcpp')#
library('Rcpp')#
#
cppFunction('#
NumericVector S2Cpi(NumericVector x) {#
	int p = x.size() - 1;#
	NumericVector phi(p);#
	for (int j = 0; j < p; ++j) {#
    double denom = 1.0;#
    for (int k = 0; k < j; ++k) {#
      denom *= sin(phi[k]);#
    }#
    phi[j] = acos(x[j] / (denom == 0 ? 1.0 : denom));#
  }#
  if ( x[p] < 0 ) {#
        phi[p-1]=2*M_PI-phi[p-1];#
    } #
  return phi;#
}#
')#
#
Cpi2S=function(Phi){#
	Phi=c(Phi,0)#
	Z=cos(Phi[1])#
	for(j in 2:(length(Phi)))Z=c(Z,cos(Phi[j])*prod(sin(Phi[1:(j-1)])))#
	return(Z)#
}#
#
cppFunction('#
NumericVector Cpi2C(NumericVector phi) {#
  int p = phi.size();#
  NumericVector u(p);#
#
  for (int j = 0; j < p - 1; ++j) {#
    // Compute I_j(phi_j) and normalize#
    double num = 0.0, denom = 0.0;#
    int N = 1000;#
    double h = M_PI / N;#
    for (int i = 0; i <= N; ++i) {#
      double t = i * h;#
      double w = (i == 0 || i == N) ? 0.5 : 1.0;#
      double f = pow(sin(t), p - j - 1);#
      if (t <= phi[j]) num += w * f;#
      denom += w * f;#
    }#
    u[j] = h * num / (h * denom);#
  }#
#
  // Final coordinate: φ_p / (2π)#
  u[p - 1] = phi[p - 1] / (2.0 * M_PI);#
#
  return u;#
}#
')#
#
U6=c()#
for(phi in seq(0,pi,length.out=1000*pi))U6=rbind(U6,Cpi2C(c(rep(phi,5),2*phi)))#
plot(U6[,1],type='l')#
for(i in 2:p)lines(U6[,i],col=i)#
C2Cpi=function(U){#
	p=length(U)#
	if(p>6)print('La dimensión no debe ser mayor que 6')#
	phi=c()#
	for (i in 1:p)phi=c(phi,max(which(U6[,6-p+i]<=U[i]))/1000)#
	phi[p]=2*phi[p]#
	return(phi)#
}#
#
C2S=function(U){#
	n=nrow(U)#
	Z=c()#
	for(i in 1:n)Z=rbind(Z,Cpi2S(C2Cpi(U[i,])))#
	return(Z)#
}#
#
S2C=function(Z){#
	if(is.matrix(Z)==TRUE) n=nrow(Z) else n=1#
	if(n==1)U=Cpi2C(S2Cpi(Z)) else {#
	U=c()#
	for(i in 1:n)U=rbind(U,Cpi2C(S2Cpi(Z[i,])))}#
	return(U)#
}#
calpowUS=function(n,p,alte,kk,n_sim){#
# Definiciones de las alternativas#
#
# 1. VMF con concentración#
mu1 <- c(1, rep(0, p - 1))#
mu1 <- mu1 / sqrt(sum(mu1^2))#
alt_vmf <- rvmf(n, mu1, k = kk)#
#
# 2. Mezcla de VMF#
mu1 <- c(1, rep(0, p - 1))#
mu1 <- mu1 / sqrt(sum(mu1^2))#
mu2 <- c(0, 1, rep(0, p - 2))#
mu2 <- mu2 / sqrt(sum(mu2^2))#
bin=rbinom(1,n,.5)#
alt_mix <- rbind(rvmf(bin, mu1, k = kk), rvmf(n-bin, mu2, k = kk))#
#
# 3. Proyección de normal anisotrópica#
Sigma <- diag(c(1+kk, rep(1, p - 1)))#
raw_aniso <- MASS::mvrnorm(n, mu = rep(0, p), Sigma = Sigma)#
alt_aniso <- raw_aniso / sqrt(rowSums(raw_aniso^2))#
#
# 4. Proyección de cópula normal#
Z <- matrix(rnorm(n*p),n,p)#
ZZ <-Z[,p]+kk*Z[,1]#
for(i in 1:(p-1))ZZ<-cbind(Z[,i]+kk*Z[,i+1])#
alt_copula <- ZZ/sqrt(rowSums(ZZ^2))#
#
# 5. Proyección de normales rho-correlacionadas#
Sigma=matrix(rep(kk/10,p^2),p,p)+diag(rep(1-kk/10,p))#
Z=rmvnorm(n,mu=rep(0,p),sigma=Sigma)#
sample=Z/sqrt(rowSums(Z^2))#
plot(0,0,xlim=c(0,n_sim),ylim=c(0,n_sim))#
#
results <- matrix(NA, nrow = n_sim, ncol = 9)#
colnames(results) <- c("Rayleigh", "Bingham", "Sobolev", "Giné Fn","HR","max","sum","maxp","sump")#
set.seed(123)#
for (i in 1:n_sim) {if(i==10*floor(i/10)){#
		lines(i,i,type='p')#
		 Sys.sleep(0.01)       # Pausa para que se vea el punto#
  				flush.console()}       # Asegura que se actualice la consola#
if(alte==1)  sample <- rvmf(n, mu1, k = kk)  # alternativa fija#
if(alte==2) {bin=rbinom(1,n,.5)#
	sample <- rbind(rvmf(bin, mu1, k = kk), rvmf(n-bin, mu2, k = kk))}#
if(alte==3){ raw_aniso <- MASS::mvrnorm(n, mu = rep(0, p), Sigma = diag(c(1+2*kk, rep(1, p - 1))))#
 sample <- raw_aniso / sqrt(rowSums(raw_aniso^2))}#
if(alte==4){Z <- matrix(rnorm(n*p),n,p)#
ZZ <-Z[,p]+kk*Z[,1]#
for (ij in 2:p)ZZ=cbind(ZZ,Z[,ij-1]+kk*Z[,ij])#
sample <- ZZ/sqrt(rowSums(ZZ^2))}#
if(alte==5){Sigma <- matrix(rep(kk/5,p^2),p,p)+diag(rep(1-kk/5,p))#
Z <- rmvnorm(n,mu=rep(0,p),sigma=Sigma)#
sample <- Z/sqrt(rowSums(Z^2))}#
#
if(alte==6){sample=muesnorm(n,p,kk/10)}#
if(alte==7){sample=muesclay(n,p,kk)}#
if(alte==8){sample=muesgumbel(n,p,kk)}#
#
 results[i, 1] <- unif_test(sample, type="Rayleigh",p_value="MC")$p.value < 0.05#
 results[i, 2] <-  unif_test(sample, type="Bingham",p_value="MC")$p.value < 0.05#
 results[i, 3] <-  unif_test(sample, type="Sobolev",p_value="MC")$p.value < 0.05#
 results[i, 4] <-  unif_test(sample, type="Gine_Fn",p_value="MC")$p.value < 0.05#
 results[i, 5] <- HR.test(sample)$p.value < 0.05#
 results[i,6:9] <- MUCS(sample,type='US',full=TRUE,repet=100)<c(.05,.05,.05,.05)#
}#
#
# Estimar potencia#
#
return(100*colMeans(results))#
#
}
n <- 50#
p <- 3#
n_sim=20#
#
powUS=matrix(NA,1,11)#
#
#load(file='powUS')#
#
pa=matrix(NA,8,3)#
pa[1,]=c(0,1,.25)#
pa[2,]=c(0,3,.5)#
pa[3,]=c(0,3,.5)#
pa[4,]=c(0,5,1)#
pa[5,]=c(0,.4,.1)#
pa[6,]=c(2,5,1)#
pa[7,]=c(.25,2,.25)#
pa[8,]=c(1,5,1)#
for(alte in 1:8){#
for(kk in c(seq(pa[alte,1],pa[alte,2],pa[alte,3]))){print(c(alte,kk))#
	powUS=rbind(powUS,c(alte,kk,calpowUS(n,p,alte,kk,n_sim)))#
}#
save(file=paste('powUS_n=',as.character(n),'_p=',as.character(p),sep=''),powUS)}
powUS
