  # To test normality, standardize the sample and apply Phi#
  if(type=='N'){#
  	ZC=Z-rep(1,nrow(Z))%*%t(colMeans(Z))#
  	variance=t(ZC)%*%ZC/nrow(Z)#
  	eig=eigen(variance)#
  	X=pnorm(ZC%*%eig$vectors%*%diag(eig$values^(-.5))%*%t(eig$vectors))#
  }	else variance<-NA#
return(list(X=X,variance=variance))#
}#
#
   # Generation of the subsets H of J={0,1,...,p}#
  genlist=function(hmin,hmax,p){#
  H_list <- list()#
  for (h in max(1,hmin):min(hmax, p)) {#
    H_list <- c(H_list, combn(p, h, simplify = FALSE))#
  }#
 if(type=='I') H_list[[p]] <- NULL#
  return(H_list)#
}#
#
  #Computation of the statistics ||T_H||^2#
  calcest=function(X,H_list){#
	T_H2=c()#
	for(H in H_list)T_H2=c(T_H2,calc_est(X,as.integer(H)))#
	return(T_H2)#
	}#
  # Simulation of samples under the null hypothesis#
  simsamp=function(n,p,variance=NA,type=type){#
	if(type=='N'){X <- rmvnorm(n,rep(0,p),variance)#
		XC=X-rep(1,nrow(X))%*%t(colMeans(X))#
  	variance=t(XC)%*%XC/nrow(X)#
  	eig=eigen(variance)#
  	X=pnorm(XC%*%eig$vectors%*%diag(eig$values^(-.5))%*%t(eig$vectors))#
		}else X <- matrix(runif(n*p),n,p)#
	if(type=='I')X[,p] <- rank(X[,p])/(n+1)#
	return(X)#
}#
#
  # Estimation of the p-values by simulation#
  calcpvals=function(T_H2,n,p,repet,H_list,variance=diag(p),type){#
  	counter=rep(0,length(T_H2))#
  	for(rep in 1:repet){#
  		if(type=='N')samp=simsamp(n,p,variance=variance,type=type) else samp=simsamp(n,p,type=type)#
  		T2=calcest(samp,H_list)#
  		counter=counter+(sign(T2-T_H2)+1)/2#
  	}#
  	return(counter/repet)#
  }#
#
if (!requireNamespace('Rcpp', quietly = TRUE))install.packages('Rcpp')#
library('Rcpp')#
#
cppFunction('#
double calc_est(NumericMatrix X, IntegerVector H) {#
  int n = X.nrow();#
  double T = 0.0;#
  for (int h = 0; h < n; ++h) {#
    for (int i = 0; i < n; ++i) {#
      double prod = 1.0;#
      for (int j = 0; j < H.size(); ++j) {#
        int col = H[j] - 1; // Convertir de 1-based (R) a 0-based (C++)#
        double val_h = X(h, col);#
        double val_i = X(i, col);#
        double term = (pow(val_h, 2.0) + pow(val_i, 2.0)) / 2.0 - std::max(val_h, val_i) + 1.0 / 3.0;#
        prod *= term;#
      }#
      T += prod;#
    }#
  }#
  return T / n;#
}#
')#
S2C=function(Z){#
	if(is.matrix(Z)==TRUE) n=nrow(Z) else n=1#
	if(n==1)U=Cpi2C(S2Cpi(Z)) else {#
	U=c()#
	for(i in 1:n)U=rbind(U,Cpi2C(S2Cpi(Z[i,])))}#
	return(U)#
}#
cppFunction('#
NumericVector Cpi2C(NumericVector phi) {#
  int p = phi.size();#
  NumericVector u(p);#
#
  for (int j = 0; j < p - 1; ++j) {#
    // Compute I_j(phi_j) and normalize#
    double num = 0.0, denom = 0.0;#
    int N = 1000;#
    double h = M_PI / N;#
    for (int i = 0; i <= N; ++i) {#
      double t = i * h;#
      double w = (i == 0 || i == N) ? 0.5 : 1.0;#
      double f = pow(sin(t), p - j - 1);#
      if (t <= phi[j]) num += w * f;#
      denom += w * f;#
    }#
    u[j] = h * num / (h * denom);#
  }#
#
  // Final coordinate: φ_p / (2π)#
  u[p - 1] = phi[p - 1] / (2.0 * M_PI);#
#
  return u;#
}#
')#
cppFunction('#
NumericVector S2Cpi(NumericVector x) {#
	int p = x.size() - 1;#
	NumericVector phi(p);#
	for (int j = 0; j < p; ++j) {#
    double denom = 1.0;#
    for (int k = 0; k < j; ++k) {#
      denom *= sin(phi[k]);#
    }#
    phi[j] = acos(x[j] / (denom == 0 ? 1.0 : denom));#
  }#
  if ( x[p] < 0 ) {#
        phi[p-1]=2*M_PI-phi[p-1];#
    } #
  return phi;#
}#
')
power(50,3,'I','I',1000)
MuniCandS <- function(Z, type, hmin = 1,hmax = Inf, repet = 999, semilla = 123) {#
  if (!is.matrix(Z)) stop("Z debe ser una matriz")#
#
  n <- nrow(Z)#
  datap=dataproc(Z,type)#
  X=datap$X#
  variance=datap$variance#
  p <- ncol(X)#
  H_list=genlist(hmin,hmax,p)#
  if(type=='I') H_list[[p]] <- NULL#
  T_H2=calcest(X,H_list)#
  pvals=calcpvals(T_H2,n,p,repet,H_list,variance=datap$variance,type=type)#
  pmin=min(pvals)#
  suma=sum(qchisq(1 - pvals, df = 1))#
  m_p_value <- 1 - (1 - pmin)^length(H_list)#
  s_p_value <- 1 - pchisq(suma, df = length(H_list))#
  return(c(m_p_value = m_p_value, s_p_value = s_p_value))#
}#
#
