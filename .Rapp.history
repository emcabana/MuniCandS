cppFunction('#
double calc_est(NumericMatrix X, IntegerVector H) {#
  int n = X.nrow();#
  double T = 0.0;#
  for (int h = 0; h < n; ++h) {#
    for (int i = 0; i < n; ++i) {#
      double prod = 1.0;#
      for (int j = 0; j < H.size(); ++j) {#
        int col = H[j] - 1; // Convertir de 1-based (R) a 0-based (C++)#
        double val_h = X(h, col);#
        double val_i = X(i, col);#
        double term = (pow(val_h, 2.0) + pow(val_i, 2.0)) / 2.0 - std::max(val_h, val_i) + 1.0 / 3.0;#
        prod *= term;#
      }#
      T += prod;#
    }#
  }#
  return T / n;#
}#
')#
S2C=function(Z){#
	if(is.matrix(Z)==TRUE) n=nrow(Z) else n=1#
	if(n==1)U=Cpi2C(S2Cpi(Z)) else {#
	U=c()#
	for(i in 1:n)U=rbind(U,Cpi2C(S2Cpi(Z[i,])))}#
	return(U)#
}#
cppFunction('#
NumericVector Cpi2C(NumericVector phi) {#
  int p = phi.size();#
  NumericVector u(p);#
#
  for (int j = 0; j < p - 1; ++j) {#
    // Compute I_j(phi_j) and normalize#
    double num = 0.0, denom = 0.0;#
    int N = 1000;#
    double h = M_PI / N;#
    for (int i = 0; i <= N; ++i) {#
      double t = i * h;#
      double w = (i == 0 || i == N) ? 0.5 : 1.0;#
      double f = pow(sin(t), p - j - 1);#
      if (t <= phi[j]) num += w * f;#
      denom += w * f;#
    }#
    u[j] = h * num / (h * denom);#
  }#
#
  // Final coordinate: φ_p / (2π)#
  u[p - 1] = phi[p - 1] / (2.0 * M_PI);#
#
  return u;#
}#
')#
cppFunction('#
NumericVector S2Cpi(NumericVector x) {#
	int p = x.size() - 1;#
	NumericVector phi(p);#
	for (int j = 0; j < p; ++j) {#
    double denom = 1.0;#
    for (int k = 0; k < j; ++k) {#
      denom *= sin(phi[k]);#
    }#
    phi[j] = acos(x[j] / (denom == 0 ? 1.0 : denom));#
  }#
  if ( x[p] < 0 ) {#
        phi[p-1]=2*M_PI-phi[p-1];#
    } #
  return phi;#
}#
')
