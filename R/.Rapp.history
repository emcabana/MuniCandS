intlin <- function(x, X, Y) {#
  n <- length(X)#
  if (n == 0) return(NA_real_)#
  # extremos#
  if (x <= X[1]) return(Y[1])#
  if (x >= X[n]) return(Y[n])#
  # buscar primer índice pos tal que X[pos] >= x#
  pos <- which(X >= x)[1]#
  # si coincide exactamente#
  if (!is.na(pos) && X[pos] == x) return(Y[pos])#
  i1 <- max(1, pos - 1)#
  i2 <- min(n, pos)#
  x1 <- X[i1]; x2 <- X[i2]#
  y1 <- Y[i1]; y2 <- Y[i2]#
  if (x2 == x1) return(y1) # degenerado#
  return(((x2 - x) * y1 + (x - x1) * y2) / (x2 - x1))#
}
intlin(.3,c(.3,.4,.5),c(.4,.6,.9))
intlin(.3,c(.3,.2,.5),c(.4,.6,.1))
intlin(.3,c(.3,.2,.1),c(.4,.1,.3))
intlin(.301,c(.3,.2,.1),c(.4,.1,.3))
n=50
nn=c(50,100,200)
intlin(n,nn,c(1,2,3))
intlin(55,nn,c(1,2,3))
intlin(155,nn,c(1,2,3))
