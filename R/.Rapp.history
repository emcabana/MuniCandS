evlin=function(u,f){ff=c(0,sort(f),1)#
	sf=max(which(ff<=u))#
	if(sf==length(ff))return(1) else return(((u-ff[sf])*(sf)+(ff[sf+1]-u)*(sf-1))/((ff[sf+1]-ff[sf])*(length(f)+1)))#
 }
x=runif(1000)^2
y=sort(x)[740]
evlin(y,x)
y=x
for(i in 1:1000)y[i]=evlin(y,x)
warnings()
